#!/usr/bin/env bash

set -u

version="1.0.6"

color_green=$'\e[32m'
color_yellow=$'\e[33m'
color_red=$'\e[31m'
color_blue=$'\e[94m'
color_white=$'\e[97m'
color_reset=$'\e[0m'

char_success="+"
char_warn="!"
char_error="x"
char_info="i"

ping_opts="-c 1 -W 2"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/netchecker"
default_config="$config_dir/hosts.json"

# -------------------------
# LOGGING
# -------------------------
log_row() {
    printf "%s[%s] %-35s %-18s %-10s %s%s\n" \
        "$5" "$1" "$2" "$3" "$4" "$6" "$color_reset"
}

ping_success() {
    log_row "$char_success" "$1" "$2" "$3" "$color_green" "reachable"
}

ping_error() {
    log_row "$char_error" "$1" "$2" "-" "$color_red" "unreachable"
}

ping_warning() {
    log_row "$char_warn" "$1" "$2" "-" "$color_yellow" "unreachable (non-critical)"
}

log_info() {
    printf "${color_blue}[$char_info] %s${color_reset}\n" "$1"
}

log_error() {
    printf "${color_red}[$char_error] %s${color_reset}\n" "$1"
}

log_success() {
    printf "${color_green}[$char_success] %s${color_reset}\n" "$1"
}

log_stat() {
    local icon="$1"
    local label="$2"
    local value="$3"
    local color="$4"

    printf "${color}[%s] %-35s %d${color_reset}\n" "$icon" "$label" "$value"
}

# -------------------------
# CHECK
# -------------------------
check() {
    local host="$1"
    local name="$2"
    local mode="${3:-}"

    local output latency
    output=$(ping $ping_opts "$host" 2>/dev/null)
    local status=$?

    if [[ $status -eq 0 ]]; then
        latency=$(echo "$output" | grep -oP 'time=\K[0-9.]+' | tail -1)
        latency="${latency:-0} ms"

        ping_success "$name" "$host" "$latency"
        return 0
    else
        if [[ "$mode" == "noncritical" ]]; then
            ping_warning "$name" "$host"
        else
            ping_error "$name" "$host"
        fi
        return 1
    fi
}

# -------------------------
# JSON PROCESSING
# -------------------------
check_json() {
    local file="$1"
    shift
    local filters=("$@")
    local first=1

    local total_fail=0
    declare -A network_status

    # validation
    if [[ ! -f "$file" ]]; then
        log_error "Config file not found: $file"
        exit 1
    fi

    if ! jq empty "$file" 2>/dev/null; then
        log_error "Invalid JSON file: $file"
        exit 1
    fi

    if ! jq -e '.networks and (.networks | type == "array")' "$file" > /dev/null; then
        log_error "Invalid format: missing 'networks' array"
        exit 1
    fi

    local found=0

    while ifs= read -r net; do
        local network fail=0 ok=0 warn_count=0

        network=$(echo "$net" | jq -r '.network // "unknown"')

        # filtering
        if [[ ${#filters[@]} -gt 0 ]]; then
            skip=1
            for f in "${filters[@]}"; do
                [[ "$network" == "$f" ]] && skip=0
            done
            [[ $skip -eq 1 ]] && continue
        fi

        found=1

        if [[ $first -eq 0 ]]; then
            echo
            log_info "------------------------------------------------------------------------"
        fi
        first=0
        log_info "Checking ${network} network"
        log_info "HOSTNAME                            IP                 LATENCY    STATUS"

        while ifs= read -r row; do
            local name ip mode

            name=$(echo "$row" | jq -r '.name')
            ip=$(echo "$row" | jq -r '.ip')
            mode=$(echo "$row" | jq -r '.mode')

            [[ "$ip" == "null" ]] && continue
            [[ "$name" == "null" || -z "$name" ]] && name="$ip"

            if [[ "$mode" == "noncritical" ]]; then
                if check "$ip" "$name" "noncritical"; then
                    ((ok++))
                else
                    ((warn_count++))
                fi
            else
                if check "$ip" "$name"; then
                    ((ok++))
                else
                    ((fail++))
                fi
            fi

        done < <(echo "$net" | jq -c '.hosts[]')

        log_info "SUMMARY: $network"
        log_stat "$char_success" "reachable"           "$ok"         "$color_green"
        log_stat "$char_warn"    "failed non-critical" "$warn_count" "$color_yellow"
        log_stat "$char_error"   "failed"              "$fail"       "$color_red"

        if [[ $fail -eq 0 ]]; then
            network_status["$network"]="ok"
        else
            network_status["$network"]="fail"
            ((total_fail++))
        fi

    done < <(jq -c '.networks[]' "$file")

    # no match
    if [[ ${#filters[@]} -gt 0 && $found -eq 0 ]]; then
        echo
        log_error "No matching networks found for filter(s): ${filters[*]}"
        exit 1
    fi

    # -------------------------
    # GLOBAL SUMMARY
    # -------------------------
    echo
    log_info "------------------------------------------------------------------------"
    log_info "SUMMARY NETWORK STATUS"

    for net in "${!network_status[@]}"; do
        if [[ "${network_status[$net]}" == "fail" ]]; then
            printf "${color_red}[✗] %-35s fail${color_reset}\n" "$net"
        fi
    done

    for net in "${!network_status[@]}"; do
        if [[ "${network_status[$net]}" == "ok" ]]; then
            printf "${color_green}[✓] %-35s ok${color_reset}\n" "$net"
        fi
    done

    # exit code
    if [[ $total_fail -gt 0 ]]; then
        exit 1
    else
        exit 0
    fi
}

show_logo() {
    local color_name="${1:-white}"
    local color

case "${color_name,,}" in
    g|green) color=$color_green ;;
    y|yellow) color=$color_yellow ;;
    r|red) color=$color_red ;;
    b|blue) color=$color_blue ;;
    w|white|"") color=$color_white ;;
    *) color=$color_white ;;
esac

    printf "%b" "${color}"
    cat << 'EOF'
  _   _ _____ _____    ____ _   _ _____ ____ _  _______ ____
 | \ | | ____|_   _|  / ___| | | | ____/ ___| |/ / ____|  _ \
 |  \| |  _|   | |   | |   | |_| |  _|| |   | ' /|  _| | |_) |
 | |\  | |___  | |   | |___|  _  | |__| |___| . \| |___|  _ <
 |_| \_|_____| |_|    \____|_| |_|_____\____|_|\_\_____|_| \_\

EOF
    printf "%b" "${color_reset}"
}

show_help() {
    show_logo g

cat << 'EOF'
netchecker - simple network health checker (JSON-based)

USAGE:
    netchecker [OPTIONS]

OPTIONS:
    -f <file>        Path to JSON config file
                     (default: ~/.config/netchecker/hosts.json)

    -n <network>     Filter specific network(s)
                     Can be used multiple times:
                     -n network-01.local -n network-02.local

    -l               List available networks from config

    -h               Show this help message

CONFIG FORMAT:
    {
      "networks": [
        {
          "network": "network-01.local",
          "hosts": [
            {
              "name": "Router #1",
              "ip": "192.168.0.1",
              "mode": "critical"
            },
            {
              "name": "Host #1",
              "ip": "192.168.0.101",
              "mode": "noncritical"
            }
          ]
        },
        {
          "network": "network-02.local",
          "hosts": [
            {
              "name": "Router #2",
              "ip": "192.168.1.1",
              "mode": "critical"
            },
            {
              "name": "Host #2",
              "ip": "192.168.1.101",
              "mode": "noncritical"
            }
          ]
        }
      ]
    }

EXAMPLES:
    netchecker
    netchecker -f network.json
    netchecker -n foo.local
    netchecker -f network.json -n network-01.local -n network-02.local
    netchecker -l

EXIT CODES:
    0   all networks ok
    1   at least one failure detected
EOF

    exit 0
}

show_version() {
    echo "netchecker ${version}"
    exit 0
}

# -------------------------
# ARG PARSING
# -------------------------
file="$default_config"
declare -a network_filters=()
list_mode=0

while getopts "f:n:lhv" opt; do
    case "$opt" in
        f)file="$OPTARG" ;;
        n) network_filters+=("$OPTARG") ;;
        l) list_mode=1 ;;
        h) show_help ;;
        v) show_version ;;
        *) echo "Usage: $0 [-f file.json] [-n network] [-l]" ; exit 1 ;;
    esac
done

# list mode
if [[ $list_mode -eq 1 ]]; then
    log_info "Available networks:"

    count=0
    while read -r net; do
        printf ">>> %-30s\n" "$net"
        ((count++))
    done < <(jq -r '.networks[].network' "$file" 2>/dev/null | sort -u)

    log_info "Total networks: $count"
    exit 0
fi

# create default config ONLY if using default path
if [[ "$file" == "$default_config" && ! -f "$file" ]]; then
    mkdir -p "$config_dir"

    cat > "$file" <<EOF
{
  "networks": [
    {
      "network": "example",
      "hosts": [
        { "name": "Cloudflare DNS", "ip": "1.1.1.1", "mode": "critical" }
      ]
    }
  ]
}
EOF

    log_info "Created default config at $file"
fi

# show config source
if [[ "$file" == "$default_config" ]]; then
    log_info "Using default config: $file"
else
    log_info "Using custom config: $file"
fi

# -------------------------
# START
# -------------------------
check_json "$file" "${network_filters[@]}"